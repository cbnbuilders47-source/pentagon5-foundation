# Development-only local infrastructure values.
# Never reuse these values outside an isolated developer workstation or CI.
POSTGRES_DB=pentagon5
POSTGRES_USER=pentagon5
POSTGRES_PASSWORD=pentagon5_dev_only
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minio_dev
MINIO_ROOT_PASSWORD=minio_dev_only_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133
PROMETHEUS_PORT=9090

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_dev_only_change_me
GRAFANA_PORT=3000

# Milestone 3 application runtime. Secret material is generated under the
# ignored .secrets/ directory by `make secrets-init`; never add it here.
P5_GATEWAY_PORT=8000
P5_LOG_LEVEL=INFO
P5_CORS_ORIGINS=http://127.0.0.1:1420,http://tauri.localhost
P5_MAX_BODY_BYTES=1048576
P5_REQUEST_TIMEOUT_SECONDS=15
P5_OIDC_ISSUER=http://host.docker.internal:8081
P5_OIDC_CLIENT_ID=pentagon5-desktop-development
P5_OIDC_REDIRECT_URI=http://127.0.0.1:8000/v1/auth/oidc/callback
P5_SESSION_TTL_SECONDS=28800
P5_OIDC_FLOW_TTL_SECONDS=300
P5_LOGIN_GRANT_TTL_SECONDS=60
P5_WS_TICKET_TTL_SECONDS=30
P5_WS_MAX_FRAME_BYTES=16384
P5_WS_MAX_SUBSCRIPTIONS=1
